{
    "name": "ermtraud/xsd-to-php-runtime",
    "description": "XML serialization and deserialization runtime for attribute-mapped PHP classes.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "xml",
        "serializer",
        "deserializer",
        "runtime"
    ],
    "require": {
        "php": "^8.3|^8.4",
        "ext-dom": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ermtraud\\XsdToPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ermtraud\\XsdToPhp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
